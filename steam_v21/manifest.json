{
  "manifest_version": 3,
  "name": "Steam Artwork Auto-Uploader",
  "version": "1.6",
  "description": "Automatically slice and upload artwork to your Steam profile",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://steamcommunity.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://steamcommunity.com/sharedfiles/edititem/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
